# msg2agent Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Relay Configuration
# =============================================================================

# Listen address for the relay server
# Default: :8080
MSG2AGENT_RELAY_ADDR=:8080

# Maximum concurrent connections
# Default: 1000
MSG2AGENT_MAX_CONNECTIONS=1000

# Message rate limit per client (messages per second)
# Default: 100.0
MSG2AGENT_MSG_RATE=100.0

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent name (required for agent)
MSG2AGENT_NAME=my-agent

# Domain for DID generation
# Default: localhost
MSG2AGENT_DOMAIN=localhost

# Relay WebSocket URL to connect to
MSG2AGENT_RELAY=ws://localhost:8080

# HTTP address for agent card serving
MSG2AGENT_HTTP=:8081

# P2P WebSocket listener address (optional, for direct connections)
MSG2AGENT_LISTEN=:8082

# Metrics server address (Prometheus)
MSG2AGENT_METRICS=:9090

# Require message encryption
# Default: false
MSG2AGENT_REQUIRE_ENCRYPTION=false

# =============================================================================
# TLS Configuration
# =============================================================================

# Enable TLS for relay/agent listener
# Default: false
MSG2AGENT_TLS=false

# Enable TLS for agent HTTP server
# Default: false
MSG2AGENT_HTTP_TLS=false

# TLS certificate file path
MSG2AGENT_TLS_CERT=/path/to/server.crt

# TLS private key file path
MSG2AGENT_TLS_KEY=/path/to/server.key

# Skip TLS verification for relay connection (development only!)
# Default: false
MSG2AGENT_TLS_SKIP_VERIFY=false

# =============================================================================
# Storage Configuration
# =============================================================================

# Store type: memory, file, sqlite
# Default: memory
MSG2AGENT_STORE=memory

# Store file path (required for file/sqlite stores)
MSG2AGENT_STORE_FILE=/var/lib/msg2agent/relay.db

# =============================================================================
# Logging and Telemetry
# =============================================================================

# Log level: debug, info, warn, error
# Default: info
MSG2AGENT_LOG_LEVEL=info

# OpenTelemetry OTLP endpoint for tracing
# Example: http://jaeger:4318
MSG2AGENT_OTLP_ENDPOINT=

# Enable stdout tracing for debugging
# Default: false
MSG2AGENT_TRACE_STDOUT=false

# =============================================================================
# Security
# =============================================================================

# Comma-separated allowed CORS origins (empty = allow all)
# CORS_ORIGINS=https://dashboard.example.com,https://app.example.com

# Comma-separated DID allowlist for relay connections (empty = allow all)
# ALLOWED_DIDS=did:web:relay.example.com,did:web:agent.example.com

# Skip DID proof verification (dev/testing only — never in production)
# Default: false
# SKIP_DID_PROOF=false

# =============================================================================
# Billing (relay / mcp-server)
# =============================================================================

# Path to the billing SQLite database (relay uses BILLING_DB; mcp-server uses MSG2AGENT_BILLING_DB)
# BILLING_DB=/var/lib/msg2agent/billing.db
# MSG2AGENT_BILLING_DB=/var/lib/msg2agent/billing.db

# Billing store backend: sqlite (default) or postgres
# BILLING_DRIVER=sqlite
# MSG2AGENT_BILLING_DRIVER=sqlite

# PostgreSQL DSN (required when BILLING_DRIVER=postgres)
# BILLING_PG_DSN=postgres://msg2agent:secret@localhost:5432/msg2agent?sslmode=disable

# Path to JSON quota overrides file (optional)
# BILLING_QUOTAS_FILE=/etc/msg2agent/quotas.json

# Webhook URL for quota-warning notifications (optional)
# BILLING_WEBHOOK_URL=https://hooks.example.com/billing

# Quota warning threshold (default: 0.8 = 80%)
# BILLING_QUOTA_WARN_RATIO=0.8

# Path to pg_dump binary for Postgres backups (optional)
# MSG2AGENT_PG_DUMP=/usr/bin/pg_dump

# API key environment prefix: live → sk_live_, test → sk_test_
# Default: test
# MSG2AGENT_ENV=live

# =============================================================================
# Stripe
# =============================================================================

# Stripe secret key (required for billing integration)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (required for webhook verification)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs per plan (required for checkout flows)
# STRIPE_PRICE_FREE=price_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# =============================================================================
# OAuth2 / JWT (relay + mcp-server use MSG2AGENT_OAUTH2_* prefix)
# =============================================================================

# OAuth2 issuer URL (e.g. https://accounts.google.com)
# MSG2AGENT_OAUTH2_ISSUER_URL=https://accounts.google.com

# OAuth2 audience (matches the "aud" claim in JWTs)
# MSG2AGENT_OAUTH2_AUDIENCE=msg2agent

# OAuth2 JWKS URL (derived from issuer if omitted)
# MSG2AGENT_OAUTH2_JWKS_URL=https://accounts.google.com/.well-known/openid-configuration

# Auto-provision a billing tenant for new OAuth2 logins (empty = disabled)
# MSG2AGENT_OAUTH_AUTO_PROVISION=free

# =============================================================================
# Dashboard (cmd/dashboard — uses OAUTH2_* without MSG2AGENT_ prefix)
# =============================================================================

# Dashboard listen address
# Default: :8082
# DASHBOARD_ADDR=:8082

# Relay base URL the dashboard proxies billing endpoints to
# RELAY_URL=http://localhost:8080

# Billing store driver for dashboard (sqlite|postgres)
# BILLING_DRIVER=sqlite

# OAuth2 config for dashboard (same values as relay/mcp-server above)
# OAUTH2_ISSUER_URL=https://accounts.google.com
# OAUTH2_AUDIENCE=msg2agent
# OAUTH2_JWKS_URL=https://accounts.google.com/.well-known/openid-configuration

# Service token for dashboard → relay internal calls
# MSG2AGENT_SERVICE_TOKEN=
