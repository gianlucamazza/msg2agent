---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---
<BaseLayout {title} {description} {ogImage}>
  <slot name="head" slot="head" />
  <nav class="landing-nav">
    <a href="/" class="logo">msg2agent</a>
    <div class="nav-links">
      <a href="/pricing">Pricing</a>
      <a href="https://github.com/gianlucamazza/msg2agent">Docs</a>
      <a href="/app/" class="btn-ghost">Sign In</a>
      <a href="/pricing" class="btn-primary">Get API Key</a>
    </div>
  </nav>
  <slot />
  <footer>
    <div>
      <a href="/">Home</a>
      <a href="/pricing">Pricing</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="https://github.com/gianlucamazza/msg2agent">GitHub</a>
    </div>
    <p class="footer-copy">&copy; 2026 msg2agent</p>
  </footer>
</BaseLayout>
