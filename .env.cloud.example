# msg2agent cloud deployment — copy to .env.cloud and fill in values
# Usage: docker compose -f infrastructure/docker-compose.cloud.yml --env-file .env.cloud up -d

# ── Domain ──────────────────────────────────────────────────────────────
DOMAIN=relay.example.com

# ── Docker images ────────────────────────────────────────────────────────
RELAY_IMAGE=ghcr.io/yourorg/msg2agent-relay:latest
MCP_IMAGE=ghcr.io/yourorg/msg2agent-mcp-server:latest

# ── Billing ──────────────────────────────────────────────────────────────
# Path inside the container for the billing SQLite DB (mounted via volume)
BILLING_DB=/data/billing.db

# Billing store backend: sqlite (default) or postgres
# MSG2AGENT_BILLING_DRIVER=sqlite

# PostgreSQL DSN (required when billing driver is postgres)
# BILLING_PG_DSN=postgres://msg2agent:secret@db:5432/msg2agent?sslmode=require

# Webhook for quota notifications (optional)
# BILLING_WEBHOOK_URL=https://hooks.example.com/billing

# Quota warning threshold (default 0.8 = 80%)
# BILLING_QUOTA_WARN_RATIO=0.8

# ── Auth / OAuth2 ────────────────────────────────────────────────────────
# OAuth2 issuer URL (e.g. https://accounts.google.com)
# MSG2AGENT_OAUTH2_ISSUER_URL=https://accounts.google.com

# OAuth2 audience
# MSG2AGENT_OAUTH2_AUDIENCE=msg2agent

# OAuth2 JWKS URL (derived from issuer if omitted)
# MSG2AGENT_OAUTH2_JWKS_URL=https://accounts.google.com/.well-known/jwks.json

# Auto-provision a billing tenant on first OAuth2 login (empty = disabled)
# MSG2AGENT_OAUTH_AUTO_PROVISION=free

# Dashboard OAuth2 (same values without MSG2AGENT_ prefix)
# OAUTH2_ISSUER_URL=https://accounts.google.com
# OAUTH2_AUDIENCE=msg2agent
# OAUTH2_JWKS_URL=https://accounts.google.com/.well-known/jwks.json

# ── API key environment ──────────────────────────────────────────────────
# Controls prefix for new API keys: "live" → sk_live_, "test" → sk_test_
MSG2AGENT_ENV=live

# ── Observability ────────────────────────────────────────────────────────
# OTLP endpoint for distributed tracing (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318

# ── Stripe ───────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FREE=price_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ── Dashboard ────────────────────────────────────────────────────────────
# DASHBOARD_ADDR=:8082
# RELAY_URL=http://relay:8080
# BILLING_DRIVER=sqlite
# MSG2AGENT_SERVICE_TOKEN=<generate with: openssl rand -hex 32>

# ── Relay ────────────────────────────────────────────────────────────────
MSG2AGENT_REQUIRE_DID_PROOF=true
